@{
    ViewData["Title"] = "Web Crawler & Search Engine";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Crawler Engine</h1>
        <p class="lead">SQLite tabanlı, derinlik kontrollü ve eşzamanlı arama motoru.</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card h-100 border-primary shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-spider me-2"></i>İndeksleme (Crawl)</h5>
                </div>
                <div class="card-body">
                    <form asp-action="StartIndex" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Başlangıç URL (Origin)</label>
                            <input type="url" name="origin" class="form-control" placeholder="https://tr.wikipedia.org" required>
                            <div class="form-text">Taramanın başlayacağı ana adres.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Derinlik (k - Hops)</label>
                            <input type="number" name="k" class="form-control" value="1" min="0" max="3">
                            <div class="form-text">Kaç tık uzağa gidilsin? (Önerilen: 1 veya 2)</div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 shadow-sm">
                            Taramayı Başlat
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card h-100 border-success shadow-sm">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-search me-2"></i>Arama (Search)</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Search" method="get">
                        <div class="input-group mb-3">
                            <input type="text" name="query" class="form-control form-control-lg" placeholder="Bir kelime yazın..." value="@ViewBag.Query" required>
                            <button class="btn btn-success px-4" type="submit border-0">Ara</button>
                        </div>
                    </form>

                    @if (ViewBag.Results != null)
                    {
                        var results = (List<WebCrawlerApp.Models.IndexEntry>)ViewBag.Results;
                        <div class="mt-4">
                            <h6><span class="badge bg-secondary">@results.Count</span> sonuç bulundu.</h6>
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm table-hover border">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>İlgili Sayfa (Relevant)</th>
                                            <th class="text-center">Hops</th>
                                            <th class="text-center">Skor</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in results)
                                        {
                                            <tr>
                                                <td style="font-size: 0.85rem; word-break: break-all;">
                                                    <a href="@item.RelevantUrl" target="_blank" class="text-decoration-none text-truncate d-inline-block" style="max-width: 300px;">
                                                        @item.RelevantUrl
                                                    </a>
                                                    <div class="text-muted small">Kaynak: @item.OriginUrl</div>
                                                </td>
                                                <td class="text-center align-middle">
                                                    <span class="badge rounded-pill bg-info text-dark">@item.Depth</span>
                                                </td>
                                                <td class="text-center align-middle fw-bold">@item.WordCount</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                    else if (ViewBag.Query != null)
                    {
                        <div class="alert alert-warning mt-3">Sonuç bulunamadı. Tarama devam ediyor olabilir.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="card border-primary shadow-sm mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Aktif Görevler</h5>
    </div>
    <div id="jobStatusContainer" class="card-body">
        <p class="text-muted small">Henüz bir tarama başlatılmadı.</p>
    </div>
</div>

@section Scripts {
    <script>
        function updateStatus() {
            fetch('/Home/GetCrawlerStatus')
                .then(res => res.json())
                .then(jobs => {
                    const container = document.getElementById('jobStatusContainer');
                    if (jobs.length === 0) return;

                    container.innerHTML = ''; // İçerideki "Bekleniyor" yazısını temizle
                    jobs.forEach(job => {
                        const badgeClass = job.status === "Done" ? "bg-success" : "bg-primary";
                        const barClass = job.status === "Done" ? "bg-success" : "progress-bar-animated progress-bar-striped bg-primary";

                        container.innerHTML += `
                            <div class="mb-3 border-bottom pb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="text-truncate small" style="max-width: 70%;">${job.originUrl}</strong>
                                    <span class="badge ${badgeClass}">${job.status}</span>
                                </div>
                                <div class="progress" style="height: 12px;">
                                    <div class="progress-bar ${barClass}" role="progressbar" style="width: ${job.percent}%"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-1" style="font-size: 0.75rem;">
                                    <span>%${job.percent} Tamamlandı</span>
                                    <span>${job.done} / ${job.total} Sayfa</span>
                                </div>
                            </div>`;
                    });
                })
                .catch(err => console.error("Status hatası:", err));
        }

        // 1.5 saniyede bir güncelle
        setInterval(updateStatus, 1500);
    </script>
}